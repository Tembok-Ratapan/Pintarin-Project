PORT=5000
NODE_ENV=development

# Frontend origins allowed to call the API.
# Use comma-separated values for preview/prod, for example:
# CLIENT_URLS=https://pintarin.vercel.app,https://pintarin-git-main.vercel.app
CLIENT_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pintarin_db

# Generate a long random value before deployment.
JWT_SECRET=replace_with_64_plus_random_characters
JWT_EXPIRES_IN=1d

AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_MS=30000
AI_REVIEW_THRESHOLD=0.7
AI_BATCH_SIZE=50

TRUST_PROXY=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=20
LOGIN_IDENTIFIER_RATE_LIMIT_MAX=8
